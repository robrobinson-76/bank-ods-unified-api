MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bank_ods

# GraphQL query protection (Ariadne layer)
GRAPHQL_MAX_DEPTH=10
GRAPHQL_MAX_ROOT_FIELDS=10
# Set to false in production to hide the schema from unknown clients
GRAPHQL_INTROSPECTION=true

# Transport enablement — everything runs in dev by default; a deployment sets
# individual transports to false until each is cleared for exposure.
# TRANSPORT_MCP_ENABLED gates the consumer MCP server (bank-ods);
# TRANSPORT_MCP_OPS_ENABLED gates the operations MCP server (bank-ods-ops,
# internal-only: raw feed inspection + operational tooling).
TRANSPORT_REST_ENABLED=true
TRANSPORT_GRAPHQL_ENABLED=true
TRANSPORT_MCP_ENABLED=true
TRANSPORT_MCP_OPS_ENABLED=true

# Data-tier exposure — which registry tiers the SDL, REST routers, MCP tool
# groups, and index bootstrap pick up (see bank_ods/models/registry.py).
EXPOSE_SEMANTIC_TIER=true
EXPOSE_RAW_TIER=true
